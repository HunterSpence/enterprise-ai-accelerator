# Anthropic API Key — required for all modules
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Model selection — defaults to claude-opus-4-6 if not set
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-6

# AWS credentials — optional, only needed for live AWS scanning
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
