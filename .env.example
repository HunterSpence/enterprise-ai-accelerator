# Anthropic API Key — required for all modules
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Model selection — defaults to claude-opus-4-6 if not set
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-6

# ---------------------------------------------------------------------------
# Source + Target Cloud Selection
# ---------------------------------------------------------------------------
# SOURCE_CLOUD: which cloud to scan / assess  (aws | azure | gcp | oci)
# TARGET_CLOUD: which cloud to migrate TO     (aws | azure | gcp | oci)
# Leave TARGET_CLOUD empty for single-cloud assessment (no migration planned)
SOURCE_CLOUD=aws
TARGET_CLOUD=

# Mock mode — set to true to run all demos without real cloud credentials
MOCK_MODE=false

# ---------------------------------------------------------------------------
# AWS credentials (SOURCE_CLOUD=aws or always needed for AWS scanning)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_SESSION_TOKEN=              # optional: for assumed roles / SSO
AWS_PROFILE=                    # optional: named profile from ~/.aws/credentials

# ---------------------------------------------------------------------------
# Azure credentials (SOURCE_CLOUD=azure or TARGET_CLOUD=azure)
# Create a Service Principal: az ad sp create-for-rbac --role Contributor
# ---------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_RESOURCE_GROUP=           # optional: scope scans to one resource group

# ---------------------------------------------------------------------------
# GCP credentials (SOURCE_CLOUD=gcp or TARGET_CLOUD=gcp)
# Create a Service Account: gcloud iam service-accounts create cloudiq-sa
# Grant roles: Viewer + Billing Account Viewer
# Download key: gcloud iam service-accounts keys create key.json --iam-account ...
# ---------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
GCP_PROJECT_ID=your_project_id
GCP_BILLING_ACCOUNT_ID=         # optional: for billing export access

# ---------------------------------------------------------------------------
# OCI credentials (SOURCE_CLOUD=oci or TARGET_CLOUD=oci)
# Generate API keys: https://docs.oracle.com/en-us/iaas/Content/API/Concepts/apisigningkey.htm
# Or use ~/.oci/config DEFAULT profile (parsed automatically if env vars absent)
# ---------------------------------------------------------------------------
OCI_TENANCY_ID=ocid1.tenancy.oc1..yourtenancy
OCI_USER_ID=ocid1.user.oc1..youruser
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=~/.oci/oci_api_key.pem
OCI_REGION=us-ashburn-1
